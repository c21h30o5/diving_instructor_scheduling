<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_instructor" model="ir.ui.view">
        <field name="name">res.users.form.inherit.instructor</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="inside">
                <group string="Instructor Settings" name="instructor_settings">
                    <field name="is_instructor"/>
                    <field name="max_students_per_slot" invisible="not is_instructor"/>
                    <field name="instructor_lang_ids" widget="many2many_tags" invisible="not is_instructor"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>